# ========== LLM 配置（必填）==========
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus
LLM_PROVIDER=agnes
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ========== 服务配置 ==========
APP_HOST=0.0.0.0
APP_PORT=7860

# ========== Agent 配置 ==========
MAX_WORKERS=6
MAX_RETRIES=2
REFLECTION_ENABLED=false
HITL_ENABLED=false
WORKFLOW_TIMEOUT=300

# ========== 搜索配置（可选）==========
TAVILY_API_KEY=

# ========== MCP 工具 ==========
MCP_TOOL_TIMEOUT=30

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7

# ========== PostgreSQL 数据库 ==========
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=agentforge
PG_USER=agentforge
PG_PASSWORD=agentforge123

# ========== Milvus 向量数据库 ==========
# 后端 方式1：Zilliz Cloud（推荐，无需 Docker）
MILVUS_URI=
MILVUS_TOKEN=
# 后端 方式2：本地 Docker Milvus
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# ========== 腾讯云 OCR（可选）==========
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
