# 后端 Docker 构建排除文件

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# 虚拟环境
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# 前端 node_modules
frontend/node_modules/

# 敏感配置
.env

# 运行时数据（通过 volume 挂载）
data/
logs/

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
test_output.txt
